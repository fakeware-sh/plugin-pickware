{
  "name": "@fakeware/plugin-pickware",
  "version": "1.0.0",
  "description": "Pickware ERP plugin for fakeware. Seed warehouses, bin locations and stock into a Shopware 6 shop running Pickware",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fakeware-sh/plugin-pickware.git"
  },
  "keywords": [
    "fakeware",
    "fakeware-plugin",
    "shopware",
    "pickware",
    "seed",
    "fixtures"
  ],
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.14"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "biome check . && bun run typecheck",
    "fix": "biome check . --write && bun run typecheck",
    "test": "bun test"
  },
  "peerDependencies": {
    "@fakeware/core": ">=0.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@fakeware/core": "0.0.9",
    "@types/bun": "1.3.14",
    "publint": "0.3.21",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  }
}
